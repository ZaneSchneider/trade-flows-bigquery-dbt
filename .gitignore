# === Python ===
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# === Secrets / credentials — never commit ===
# GCP service-account key filenames are arbitrary, so the reliable guard is to
# keep the key inside secrets/ and point GOOGLE_APPLICATION_CREDENTIALS at it.
secrets/
.env
.env.*
*-key.json
*credentials*.json
service-account*.json
sa-*.json

# === Local data lake / fetcher working files ===
/data/
data/

# === dbt build artifacts (restore with `dbt deps` / `dbt build`) ===
target/
dbt_packages/
logs/
.user.yml

# === Terraform (state also covered by terraform/.gitignore) ===
**/.terraform/
*.tfstate
*.tfstate.*
crash.log

# === Airflow ===
airflow.db
*.pid

# === OS / IDE ===
.DS_Store
.idea/
.vscode/